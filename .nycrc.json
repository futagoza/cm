{
    "all": true,
    "cache": true,
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "**/*.d.ts",
        "**/*.spec.ts",
        "**/*.test.ts"
    ],
    "extension": [
        ".ts"
    ],
    "require": [
        "ts-node/register"
    ],
    "reporter": [
        "json",
        "text"
    ]
}
